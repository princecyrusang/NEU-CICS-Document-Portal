
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user profile and authorization data for CICS Document Repository.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "program": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role", "isBlocked"]
    },
    "AcademicDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AcademicDocument",
      "type": "object",
      "description": "Metadata for uploaded academic resources stored in the 'documents' collection.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Enrollment & Subjects", "OJT & Internship", "Graduation", "Administrative Requests", "Department Memos", "Other"] },
        "program": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "downloadCount": { "type": "number" },
        "uploadedBy": { "type": "string" }
      },
      "required": ["title", "category", "program", "fileUrl", "uploadDate", "downloadCount"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Individual user profiles, restricted to @neu.edu.ph accounts."
        }
      },
      {
        "path": "/documents/{docId}",
        "definition": {
          "entityName": "AcademicDocument",
          "description": "Metadata for repository files, searchable by students."
        }
      }
    ]
  }
}
