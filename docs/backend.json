
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user profile and authorization data for NEU CICS Portal.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "program": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role", "isBlocked"]
    },
    "AcademicDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AcademicDocument",
      "type": "object",
      "description": "Metadata and Base64 file data for academic resources.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Academic & Enrollment", "Internship & OJT", "Graduation Requirements", "Student Records & Transfer"] },
        "program": { "type": "string" },
        "fileData": { "type": "string", "description": "Base64 encoded string of the PDF file." },
        "fileName": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "downloadCount": { "type": "number" },
        "uploadedBy": { "type": "string" }
      },
      "required": ["title", "category", "program", "fileData", "fileName", "uploadDate", "downloadCount"]
    },
    "ActivityLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActivityLog",
      "type": "object",
      "description": "Standardized audit logs for portal activities.",
      "properties": {
        "userEmail": { "type": "string", "format": "email" },
        "fileName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string", "enum": ["download", "upload", "login"] }
      },
      "required": ["userEmail", "fileName", "timestamp", "action"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles, restricted to @neu.edu.ph accounts."
    },
    "/documents/{docId}": {
      "schema": "AcademicDocument",
      "description": "Metadata and Base64 encoded PDF files for the repository."
    },
    "/logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Standardized activity logs for analytics and auditing."
    }
  }
}
