
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to verify the user is signed in with an official university email
    function isSignedIn() {
      return request.auth != null && 
             request.auth.token.email.endsWith('@neu.edu.ph');
    }
    
    // Helper to check if a user is NOT blocked by admin
    function isNotBlocked() {
      let userId = request.auth.uid;
      let userDocPath = /databases/$(database)/documents/users/$(userId);
      return isSignedIn() && (
        !exists(userDocPath) || 
        get(userDocPath).data.get('isBlocked', false) == false
      );
    }
    
    // Helper to verify administrative privileges
    function isAdmin() {
      let userId = request.auth.uid;
      let userDocPath = /databases/$(database)/documents/users/$(userId);
      return isSignedIn() && 
             exists(userDocPath) && 
             get(userDocPath).data.get('role', 'student') == 'admin';
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Allow users to update their own profile (except for role changes), or admins to update everything
      allow update: if (isSignedIn() && request.auth.uid == userId && request.resource.data.get('role', 'student') == resource.data.get('role', 'student')) || isAdmin();
      allow delete: if false;
    }

    match /documents/{docId} {
      // Allow read access for any verified student who isn't blocked
      allow read: if isNotBlocked();
      
      // Restricted to admins only for content management
      allow write: if isAdmin();
    }

    match /logs/{logId} {
      // Students can record their download activity
      allow create: if isNotBlocked();
      // Only admins can audit the logs
      allow read: if isAdmin();
    }
  }
}
